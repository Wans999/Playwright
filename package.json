{
  "name": "playwright",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "rm -rf allure-results && cucumber-js",
    "test:negative": "cucumber-js --tags @negative",
    "test:positive": "cucumber-js --tags @positive",
    "test:headed": "cucumber-js --world-parameters '{\"headless\":false}'",
    "report": "node generate-report.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@cucumber/cucumber": "^12.9.0",
    "@cucumber/pretty-formatter": "^3.3.1",
    "@playwright/test": "^1.60.0",
    "allure-commandline": "^2.42.1",
    "allure-cucumberjs": "^3.10.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "playwright": "^1.60.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
